NODE_ENV=development
PORT=5000
API_BASE_PATH=/api

# Comma-separated list of allowed origins (local dev examples)
CORS_ORIGINS=http://localhost:5173,http://127.0.0.1:5173

# MongoDB Atlas connection string
MONGODB_URI=mongodb+srv://<user>:<password>@<cluster>/<db>?retryWrites=true&w=majority

# JWT
JWT_ACCESS_SECRET=change_me_access_secret
JWT_ACCESS_EXPIRES_IN=7d

# Admin bootstrap (used by seed script)
ADMIN_EMAIL=admin@arena.com
ADMIN_PASSWORD=ChangeThisAdminPassword123!
ADMIN_USERNAME=admin

# Razorpay (real payments)
RAZORPAY_KEY_ID=
RAZORPAY_KEY_SECRET=
RAZORPAY_WEBHOOK_SECRET=

# Referral bonus (credited to referrer on successful signup)
REFERRAL_BONUS_AMOUNT=10

